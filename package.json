{
  "name": "logtriage",
  "version": "0.1.0",
  "description": "Local-first CLI for turning noisy command logs into concise triage reports.",
  "type": "module",
  "main": "./dist/src/index.js",
  "bin": {
    "logtriage": "./dist/src/cli.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "logs",
    "triage",
    "diagnostics",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/logtriage.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/logtriage/issues"
  },
  "homepage": "https://github.com/rogerchappel/logtriage#readme"
}
